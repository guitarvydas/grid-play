% rewrite strexpander {
  main [char+] = ‛«char»’
  char_decl [decl] = ‛«decl»’
  char_interpstring [s] = ‛«s»’
  char_other [c] = ‛«c»’
  Decl [ws _colon id _eq e ws2] = ‛«ws»«_colon»«id»«_eq»«e»«ws2»’
  interpString [_dollar f? m t?] = ‛"«f»" + "str(«m»)" + "«t»"’
  strFront [lq cs+] = ‛«cs»’
  strMiddle [lb cs+ rb] = ‛«cs»’
  strTail [cs+ rq] = ‛«cs»’
  id [c cs*] = ‛«c»«cs»’
  Expr_str [s] = ‛«s»’
  str [lq cs* rq] = ‛«lq»«cs»«rq»’
}
