pythonize {
  main = char+
  char =
    | ":"                          -- colon
    | applySyntactic<Amp1>         -- amp1
    | applySyntactic<Amp2>         -- amp2
    | applySyntactic<AssignCell>   -- assigncell
    | any                          -- other
  Amp1 = #spaces "&" "\"" #spaces
  Amp2 = #spaces "&" id #spaces
  AssignCell = "[" cellid "]" "=" #(~nl any)* nl
  nl = "\n" | end
  id = (letter | "_") (alnum | "_")*
  cellid = (letter | "_")+ digit*
}
