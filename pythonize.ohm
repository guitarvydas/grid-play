pythonize {
  main = char+
  char =
    | ":"                          -- colon
    | applySyntactic<Amp1>         -- amp1
    | applySyntactic<Amp2>         -- amp2
    | any                          -- other
  Amp1 = #spaces "&" "\"" #spaces
  Amp2 = #spaces "&" id #spaces
  id = (letter | "_") (alnum | "_")*
}
