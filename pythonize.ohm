pythonize {
  main = char+
  char =
    | ":"                          -- colon
    | applySyntactic<Amp1>         -- amp1
    | applySyntactic<Amp2>         -- amp2
    | applySyntactic<Amp3>         -- amp3
    | applySyntactic<Amp4>         -- amp4
    | any                          -- other
  Amp1 = #spaces "\"" "&" "\"" #spaces
  Amp2 = #spaces id "&" "\"" #spaces
  Amp3 = #spaces "\"" "&" id #spaces
  Amp4 = #spaces id "&" id #spaces
  id = (letter | "_") (alnum | "_")*
}
