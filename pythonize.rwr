% rewrite strexpander {
  main [char+] = ‛«char»’
  char_colon [c] = ‛’
  Amp1 [ws _amp q ws2] = ‛«ws» + «q»«ws2»⎨xcontinue⎬’
  Amp2 [ws _amp id ws2] = ‛«ws» + str(«id»)«ws2»⎨xcontinue⎬’
  AssignCell [lb id rb eq cs* nl] = ‛\nimport rtlib\nrtlib.cellAssign («id», «cs»«nl»)⎨xcontinue⎬’
  id [c cs*] = ‛«c»«cs»’
  cellid [letters+ digits*] = ‛"«letters»", "«digits»"’
  nl [c] = ‛«c»’
  spaces [cs*] = ‛«cs»’
}
