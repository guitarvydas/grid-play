% rewrite strexpander {
  main [char+] = ‛import rtlib\n«char»’
  char_colon [c] = ‛’
  Amp1 [ws _amp q ws2] = ‛«ws» + «q»«ws2»’
  Amp2 [ws _amp id ws2] = ‛«ws» + str(«id»)«ws2»’
  AssignCell [lb id rb eq cs* nl] = ‛\nrtlib.cellAssign («id», «cs»«nl»)’
  id [c cs*] = ‛«c»«cs»’
  cellid [letters+ digits*] = ‛"«letters»", "«digits»"’
  nl [c] = ‛«c»’
  spaces [cs*] = ‛«cs»’
}
